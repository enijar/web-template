{
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=24",
    "npm": ">=11"
  },
  "scripts": {
    "start": "NODE_ENV=development conc -n client,server,emails \"npm run start:client\" \"npm run start:server\" \"npm run start:emails\"",
    "build": "NODE_ENV=production npm run build:client && npm run build:server",
    "check": "tsc --noEmit",
    "format": "prettier --write src",
    "start:emails": "email dev -d src/emails -p 9999",
    "start:client": "vite",
    "start:server": "tsx --watch src/server/index.ts",
    "build:client": "vite build",
    "build:server": "rm -rf build/{config,server} && tsc -p tsconfig.server.json && tsc-alias -p tsconfig.server.json",
    "env:encrypt:dev": "dotenvx encrypt -f .env.dev",
    "env:encrypt:prod": "dotenvx encrypt -f .env.prod",
    "env:decrypt:dev": "dotenvx decrypt -f .env.dev",
    "env:decrypt:prod": "dotenvx decrypt -f .env.prod"
  },
  "dependencies": {
    "@dotenvx/dotenvx": "1.71.3",
    "@hono/node-server": "2.0.4",
    "@hono/trpc-server": "0.4.2",
    "@react-email/body": "0.3.0",
    "@react-email/ui": "6.6.0",
    "@sendgrid/mail": "8.1.6",
    "@sequelize/core": "7.0.0-alpha.48",
    "@sequelize/mysql": "7.0.0-alpha.48",
    "@sequelize/sqlite3": "7.0.0-alpha.48",
    "@tanstack/react-query": "5.101.0",
    "@trpc/client": "11.17.0",
    "@trpc/react-query": "11.17.0",
    "@trpc/server": "11.17.0",
    "argon2": "0.44.0",
    "dotenv": "17.4.2",
    "hono": "4.12.25",
    "jose": "6.2.3",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router-dom": "7.17.0",
    "styled-components": "6.4.2",
    "zod": "4.4.3",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@types/node": "25.9.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "babel-plugin-styled-components": "2.3.0",
    "concurrently": "10.0.3",
    "prettier": "3.8.4",
    "react-email": "6.6.0",
    "tsc-alias": "1.8.17",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vite": "8.0.16"
  }
}
